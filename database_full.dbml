Table "trip_stop_events" {
  "event_id" uuid [not null, default: `gen_random_uuid()`]
  "stop_id" uuid [not null]
  "event_type" "character varying(50)" [not null]
  "event_time" timestamp [not null, default: `CURRENT_TIMESTAMP`]
  "meta_data" text
  
  Indexes {
    event_id [pk]
    stop_id [name: "IX_trip_stop_events_stop_id"]
  }
}

Ref "fk_trip_stop_events_stop":"trip_stops"."stop_id" < "trip_stop_events"."stop_id" [delete: cascade]

Table "detention_charges" {
  "charge_id" uuid [not null, default: `gen_random_uuid()`]
  "stop_id" uuid [not null]
  "customer_id" uuid
  "free_minutes_allocated" integer [not null, default: 30]
  "actual_wait_minutes" integer [not null]
  "amount_charged" numeric(15,2) [not null]
  "status" "character varying(20)" [not null, default: `'UNPAID'::charactervarying`]
  
  Indexes {
    charge_id [pk]
    stop_id [name: "IX_detention_charges_stop_id"]
    customer_id [name: "IX_detention_charges_customer_id"]
  }
}

Ref "fk_detention_charges_stop":"trip_stops"."stop_id" < "detention_charges"."stop_id" [delete: cascade]
Ref "fk_detention_charges_customer":"customers"."customer_id" < "detention_charges"."customer_id" [delete: set null]

Table "incident_evidences" {
  "evidence_id" uuid [not null, default: `gen_random_uuid()`]
  "incident_id" uuid [not null]
  "evidence_type" "character varying(50)" [not null]
  "file_url" "character varying(500)" [not null]
  
  Indexes {
    evidence_id [pk]
    incident_id [name: "IX_incident_evidences_incident_id"]
  }
}

Ref "fk_incident_evidences_incident":"incident_reports"."incident_id" < "incident_evidences"."incident_id" [delete: cascade]

Ref "fk_alert_logs_lpn":"lpns"."lpn_id" < "alert_logs"."lpn_id" [delete: set null]

Ref "fk_claims_lpn":"lpns"."lpn_id" < "claims"."lpn_id" [delete: set null]

Ref "fk_expense_receipts_trip":"master_trips"."trip_id" < "expense_receipts"."trip_id" [delete: cascade]

