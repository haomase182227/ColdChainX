Table "compliance_zoning_rules" {
  "rule_id" uuid [not null, default: `gen_random_uuid()`]
  "product_category" integer [not null]
  "sub_category" integer [not null]
  "requirement_level" integer [not null]
  "is_active" boolean [not null, default: true]
  "created_at" timestamp [not null, default: `CURRENT_TIMESTAMP`]
  "created_by" uuid [not null]
  "updated_at" timestamp
  "updated_by" uuid

  Indexes {
    rule_id [pk, name: "compliance_zoning_rules_pkey"]
    (product_category, sub_category) [unique, name: "uq_rule_category_subcategory"]
  }
}

